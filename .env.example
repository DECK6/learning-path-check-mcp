PORT=8080
TIME_ZONE=Asia/Seoul
# Generate once: openssl rand -base64 48
# Reuse the same secret for this store's lifetime and across all replicas. Rotation orphans existing scopes.
# USER_SCOPE_SALT=
# Single-instance persistent file store (choose a writable path):
# STORE_PATH=./data/learning-path-store.json
# Multi-instance production store:
# DATABASE_URL=postgres://user:password@host:5432/database
